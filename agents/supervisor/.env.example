# Supervisor Agent — Environment Variables
# Copy to .env for local development. On AgentCore, these are set by the runtime.

AWS_REGION=us-east-1

# AWS account ID (used to derive bucket names; auto-detected via STS if not set)
AWS_ACCOUNT_ID=<YOUR_AWS_ACCOUNT_ID>

# S3 bucket for config and documents (defaults to document-processing-<AWS_ACCOUNT_ID>)
# CONFIG_BUCKET=document-processing-<YOUR_AWS_ACCOUNT_ID>

# LLM Gateway URL (internal ALB endpoint — uses HTTP within VPC, or HTTPS via CloudFront)
LLM_GATEWAY_URL=http://<YOUR_ALB_DNS_NAME>

# LLM Gateway API key (for local dev; in production, loaded from Secrets Manager)
# LLM_GATEWAY_API_KEY=sk-your-api-key

# Secrets Manager ARN for the API key (production — from LLM Gateway CDK output)
LLM_GATEWAY_API_KEY_SECRET_ARN=arn:aws:secretsmanager:us-east-1:<ACCOUNT_ID>:secret:document-processing/llm-gateway/admin-key-XXXXXX
