# Workflow — Environment Variables
# Copy to .env for local development. In Lambda, these are set by CDK.

AWS_REGION=us-east-1

# S3 bucket for documents
DOCUMENT_BUCKET=document-processing-<YOUR_AWS_ACCOUNT_ID>

# Bedrock AgentCore supervisor runtime ARN
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:<REGION>:<YOUR_AWS_ACCOUNT_ID>:runtime/<YOUR_AGENT_ID>

# DynamoDB tables
DOCUMENTS_TABLE=DocumentProcessing-Documents
TASK_TOKEN_TABLE=DocumentProcessing-ScanTaskTokens

# Backend notify Lambda ARN (set after deploying backend stack)
NOTIFY_FUNCTION_ARN=
