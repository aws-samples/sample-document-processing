# Backend — Environment Variables
# Copy to .env for local development. In Lambda, these are set by CDK.

AWS_REGION=us-east-1

# DynamoDB tables
DOCUMENTS_TABLE=DocumentProcessing-Documents
CONNECTIONS_TABLE=DocumentProcessing-WebSocketConnections

# S3 bucket for uploaded documents and processing output
DOCUMENT_BUCKET=document-processing-<YOUR_AWS_ACCOUNT_ID>

# WebSocket API endpoint (set after deploying backend stack)
WEBSOCKET_API_ENDPOINT=

# Step Functions state machine ARN (set after deploying workflow stack)
WORKFLOW_STATE_MACHINE_ARN=

# Pre-signed URL expiry in seconds
PRESIGNED_URL_EXPIRY=3600
